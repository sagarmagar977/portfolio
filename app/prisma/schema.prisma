generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  googleId     String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  profile      Profile?
}

model Profile {
  id                  String       @id @default(cuid())
  adminUserId         String       @unique
  slug                String       @unique
  templateKey         String       @default("classic")
  roles               String[]     @default(["developer"])
  fullName            String
  heroTitlePrefix     String?
  heroHighlight       String?
  heroTitleSuffix     String?
  heroDescription     String?
  location            String?
  profileImageUrl     String?
  cvFileUrl           String?
  aboutSectionTitle   String?
  isPublished         Boolean      @default(false)
  publishedSlug       String?      @unique
  publishedAt         DateTime?
  publishedSnapshot   Json?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  adminUser           AdminUser    @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  services            Service[]
  projects            Project[]
  beats               Beat[]
  educations          Education[]
  experiences         Experience[]
  socialLinks         SocialLink[]
  businesses          Business[]
  photoProjects       PhotoProject[]
  motionProjects      MotionProject[]
  artworks            Artwork[]
  contactInfo         ContactInfo?
}

model Service {
  id          String   @id @default(cuid())
  profileId   String
  title       String
  description String
  iconName    String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Project {
  id          String   @id @default(cuid())
  profileId   String
  title       String
  description String
  imageUrl    String?
  liveUrl     String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Beat {
  id            String   @id @default(cuid())
  profileId     String
  title         String
  description   String
  coverImageUrl String?
  audioUrl      String?
  externalUrl   String?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  profile       Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Business {
  id           String   @id @default(cuid())
  profileId    String
  name         String
  businessType String?
  description  String
  websiteUrl   String?
  imageUrl     String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  profile      Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model PhotoProject {
  id          String   @id @default(cuid())
  profileId   String
  title       String
  collection  String?
  description String
  imageUrl    String?
  projectUrl  String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model MotionProject {
  id              String   @id @default(cuid())
  profileId       String
  title           String
  toolName        String?
  description     String
  previewImageUrl String?
  previewGifUrl   String?
  previewVideoUrl String?
  projectUrl      String?
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  profile         Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Artwork {
  id            String   @id @default(cuid())
  profileId     String
  title         String
  medium        String?
  description   String
  imageUrl      String?
  collectionUrl String?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  profile       Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Education {
  id          String   @id @default(cuid())
  profileId   String
  degree      String
  institution String
  period      String
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Experience {
  id          String   @id @default(cuid())
  profileId   String
  role        String
  company     String
  period      String
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model ContactInfo {
  id             String   @id @default(cuid())
  profileId      String   @unique
  sectionLabel   String?
  heading        String?
  description    String?
  phone          String?
  email          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  profile        Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model SocialLink {
  id          String   @id @default(cuid())
  profileId   String
  platform    String
  url         String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}
